{
  "permissions": {
    "allow": [
      "Agent",
      "Skill(update-config)",
      "WebSearch",
      "WebFetch(domain:support.anthropic.com)",
      "WebFetch(domain:support.claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "Read(//private/tmp/**)",
      "mcp__claude_ai_Google_Calendar__list_calendars",
      "mcp__claude_ai_Google_Calendar__create_event",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git restore *)",
      "Bash(git rm *)",
      "Bash(gh api *)",
      "Bash(gitleaks detect *)",
      "Bash(brew install *)",
      "Bash(brew services *)",
      "Bash(brew list *)",
      "Bash(npm create *)",
      "Bash(npm install *)",
      "Bash(npm test *)",
      "Bash(npm run *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(python3 -c ' *)",
      "Bash(python3 -m venv .venv)",
      "Bash(/opt/homebrew/bin/python3 *)",
      "Bash(pip install *)",
      "Bash(.venv/bin/pip install *)",
      "Bash(.venv/bin/pytest *)",
      "Bash(ollama list *)",
      "Bash(ollama pull *)",
      "Bash(ollama ps *)",
      "Bash(docker *)",
      "Bash(psql *)",
      "Bash(sqlite3 *)",
      "Bash(launchctl load *)",
      "Bash(launchctl list *)",
      "Bash(launchctl unload *)",
      "Bash(bash *)",
      "Bash(open *)",
      "Bash(date *)",
      "Bash(sleep *)",
      "Bash(ps *)",
      "Bash(lsof *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(curl *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(tail *)",
      "Bash(head *)",
      "Bash(wc *)",
      "Bash(sed *)",
      "Bash(echo *)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude_follow_record.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "padding": 0,
    "refreshInterval": 10
  },
  "effortLevel": "xhigh"
}
